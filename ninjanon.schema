-- Name: FUNCTION pseudo_addr(seed anyelement, salt text); Type: SECURITY LABEL; Schema: custanon; Owner: ninjanon
--

SECURITY LABEL FOR anon ON FUNCTION custanon.pseudo_addr(seed anyelement, salt text) IS 'TRUSTED';


