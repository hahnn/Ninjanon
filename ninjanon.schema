  FROM custanon.streets
  WHERE oid = anon.projection_to_oid(
    seed,
    COALESCE(salt, pg_catalog.current_setting('anon.salt')),
    (SELECT max(oid) FROM custanon.streets)
  );

  RETURN result;
END;
$$;


