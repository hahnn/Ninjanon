    LANGUAGE sql STABLE SECURITY DEFINER PARALLEL SAFE
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $$
  SELECT numero || COALESCE(rep, '') || ' ' || COALESCE(nom_voie, '') || ' - ' || COALESCE(cp, '') || ' ' || city FROM custanon.streets_fra
  WHERE oid = anon.projection_to_oid(
    seed,
    COALESCE(salt, pg_catalog.current_setting('anon.salt')),
    (SELECT last_value FROM custanon.streets_fra_oid_seq)
  );
$$;


