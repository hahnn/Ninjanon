  -- It returns always the same result according to its input data.
  --
  SELECT val || ', ' || anon.projection_to_oid(seed, COALESCE(salt, pg_catalog.current_setting('anon.salt')), 117) || ' - ' || cp || ' ' || city FROM custanon.streets
  WHERE oid = anon.projection_to_oid(
    seed,
    COALESCE(salt, pg_catalog.current_setting('anon.salt')),
    (SELECT last_value FROM custanon.streets_oid_seq)
  );
$$;


