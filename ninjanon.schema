--
-- Name: pseudo_first_name(anyelement, character, text); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.pseudo_first_name(seed anyelement, gender character DEFAULT NULL::character(1), salt text DEFAULT NULL::text) RETURNS text
    LANGUAGE plpgsql STABLE SECURITY DEFINER PARALLEL SAFE
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $$
DECLARE
  result TEXT;
BEGIN
  -- This is an anonymization function used to return a first name
  -- extracted from the first_name_m, first_name_f or first_name dictionnaries
  -- (SQL tables custanon.first_name_m, custanon.first_name_f, custanon.first_name)
  -- depending of the gender as input parameter.
  -- It returns always the same result according to its input data.
  --
  IF gender='m' THEN
    SELECT COALESCE(val,anon.notice_if_not_init()) INTO result
    FROM custanon.first_name_m
    WHERE oid = anon.projection_to_oid(
      seed,
      COALESCE(salt, pg_catalog.current_setting('anon.salt')),
      (SELECT max(oid) FROM custanon.first_name_m)
    );
  ELSEIF gender='f' THEN
    SELECT COALESCE(val,anon.notice_if_not_init()) INTO result
    FROM custanon.first_name_f
    WHERE oid = anon.projection_to_oid(
      seed,
      COALESCE(salt, pg_catalog.current_setting('anon.salt')),
      (SELECT max(oid) FROM custanon.first_name_f)
    );
  ELSE
    SELECT COALESCE(val,anon.notice_if_not_init()) INTO result
    FROM custanon.first_name
    WHERE oid = anon.projection_to_oid(
      seed,
      COALESCE(salt, pg_catalog.current_setting('anon.salt')),
      (SELECT max(oid) FROM custanon.first_name)
    );
  END IF;

  RETURN result;
END;
$$;


ALTER FUNCTION custanon.pseudo_first_name(seed anyelement, gender character, salt text) OWNER TO ninjanon;

--
-- Name: FUNCTION pseudo_first_name(seed anyelement, gender character, salt text); Type: SECURITY LABEL; Schema: custanon; Owner: ninjanon
--

SECURITY LABEL FOR anon ON FUNCTION custanon.pseudo_first_name(seed anyelement, gender character, salt text) IS 'TRUSTED';


--
-- Name: pseudo_last_name_u(anyelement, text); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.pseudo_last_name_u(seed anyelement, salt text DEFAULT NULL::text) RETURNS text
    LANGUAGE sql STABLE SECURITY DEFINER PARALLEL SAFE
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $$
  -- This is an anonymization function used to return a UPPER CASE last name
  -- extracted from the last_name dictionnary (SQL table anon.last_name).
  -- depending of the gender as input parameter.
  -- It returns always the same result according to its input data.
  --
  SELECT COALESCE(pg_catalog.upper(val),anon.notice_if_not_init())
  FROM anon.last_name
  WHERE oid = anon.projection_to_oid(
    seed,
    COALESCE(salt, pg_catalog.current_setting('anon.salt')),
    (SELECT max(oid) FROM anon.last_name)
  );
$$;


ALTER FUNCTION custanon.pseudo_last_name_u(seed anyelement, salt text) OWNER TO ninjanon;

--
-- Name: FUNCTION pseudo_last_name_u(seed anyelement, salt text); Type: SECURITY LABEL; Schema: custanon; Owner: ninjanon
--

SECURITY LABEL FOR anon ON FUNCTION custanon.pseudo_last_name_u(seed anyelement, salt text) IS 'TRUSTED';


--
-- Name: pseudo_street(anyelement, text); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.pseudo_street(seed anyelement, salt text DEFAULT NULL::text) RETURNS text
    LANGUAGE plpgsql STABLE SECURITY DEFINER PARALLEL SAFE
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $$
DECLARE
  result TEXT;
BEGIN
  -- This is an anonymization function used to return a street
  -- name extracted from the streets dictionnary (SQL table custanon.streets).
  -- It returns always the same result according to its input data.
  --
  SELECT COALESCE(val, anon.notice_if_not_init()) INTO result
  FROM custanon.streets
  WHERE oid = anon.projection_to_oid(
    seed,
    COALESCE(salt, pg_catalog.current_setting('anon.salt')),
    (SELECT max(oid) FROM custanon.streets)
  );

  RETURN result;
END;
$$;


ALTER FUNCTION custanon.pseudo_street(seed anyelement, salt text) OWNER TO ninjanon;

--
-- Name: FUNCTION pseudo_street(seed anyelement, salt text); Type: SECURITY LABEL; Schema: custanon; Owner: ninjanon
--

SECURITY LABEL FOR anon ON FUNCTION custanon.pseudo_street(seed anyelement, salt text) IS 'TRUSTED';


--
-- Name: pwdfile(text); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.pwdfile(file text) RETURNS SETOF text
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- the pwdfile function is used to read the content of a text file
  -- inside the filesystem. This content must be only a unique line of text
  -- and this is to simply take the password needed to connect on the
  -- source database. By the way, Ninjanon proceed this way to avoid providing
  -- your database passwords in clear directly as a parameter of the Ninjanon
  -- functions.
  --
  CREATE TEMP TABLE IF NOT EXISTS tmp_pwdfile (content text) ON COMMIT DROP;
  EXECUTE 'COPY tmp_pwdfile FROM ''' || file || '''';
  RETURN QUERY SELECT content FROM tmp_pwdfile LIMIT 1;
END;
$$;


ALTER FUNCTION custanon.pwdfile(file text) OWNER TO ninjanon;

--
-- Name: reset_anon(bigint); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.reset_anon(v_dbid bigint) RETURNS void
    LANGUAGE plpgsql
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $$
DECLARE
BEGIN
  -- The reset_anon function is used to reset the anonymization results of
  -- a previously executed anonymization. Of course that will not change the
  -- anonymized DATA if they have been injected in the target (or source) database
  -- but it's used when the anonymization model for a source database is under
  -- construction: it allows to restart the anonymization process again and
  -- again until you're happy with the results and without resetting some data
  -- but only the ones needed.
  --
  UPDATE custanon.parallel SET state='wait', startedat=NULL, endedat=NULL WHERE dbid=v_dbid;
  UPDATE custanon.counts SET startedat=NULL, endedat=NULL, error=false, err_msg=NULL, err_detail=NULL, err_hint=NULL, err_sqlstate=NULL, csvinject_time=NULL, rebuild_time=NULL, pid=NULL, anon_time=NULL WHERE dbid=v_dbid;
END;
$$;


ALTER FUNCTION custanon.reset_anon(v_dbid bigint) OWNER TO ninjanon;

--
-- Name: setconfig(text, text); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.setconfig(v_var text, v_val text) RETURNS void
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- the setconfig function is used to add or update a configuration
  -- parameter with its value in the config SQL table.
  --
  INSERT INTO custanon.config(var, val) VALUES (v_var, v_val) ON CONFLICT(var) DO UPDATE SET val=v_val, updatedon=now();
END;
$$;


ALTER FUNCTION custanon.setconfig(v_var text, v_val text) OWNER TO ninjanon;

--
-- Name: splitter(text, bigint, text, text); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.splitter(v_projectname text, v_dbid bigint, v_tbl text, v_srcfile text) RETURNS void
    LANGUAGE plpgsql SECURITY DEFINER
    AS $_$
DECLARE
  nblines integer := (custanon.getconfig('splitter', '400000')::integer);
  nbentries integer;
  cmd text;
BEGIN
  -- The splitter function splits the source file into several files
  -- and record the file parts in splitter table.
  -- The original file MUST be a CSV text file.
  --
  cmd := format(
    $f$
    COPY tmp_splitter_%s(content) FROM PROGRAM 'split --verbose -l %s -a 8 -d %s %s.'
    $f$,
    v_tbl, nblines, v_srcfile, v_srcfile);
  EXECUTE 'CREATE TEMP TABLE IF NOT EXISTS tmp_splitter_' || v_tbl || ' (dbid bigint default ' || v_dbid || ', tbl text default ''' || v_tbl || ''', content text, insertedat timestamp not null default now()) ON COMMIT DROP';
  EXECUTE cmd;
  EXECUTE 'SELECT count(*) FROM tmp_splitter_' || v_tbl || ' WHERE dbid=' || v_dbid || ' AND tbl=''' || v_tbl || '''' INTO nbentries;
  EXECUTE 'INSERT INTO custanon.splitter(projectname, nb, dbid, tbl, content, insertedat) SELECT ''' || v_projectname || ''', ' || nbentries || ', dbid, tbl, content, insertedat FROM tmp_splitter_' || v_tbl;

  -- Delete the source file once splitted
  --
  cmd := format(
    $f$
    COPY tmp_splitter_%s(content) FROM PROGRAM 'rm -f %s'
    $f$,
    v_tbl, v_srcfile);
  EXECUTE cmd;
END;
$_$;


ALTER FUNCTION custanon.splitter(v_projectname text, v_dbid bigint, v_tbl text, v_srcfile text) OWNER TO ninjanon;

--
-- Name: start_anon(bigint); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.start_anon(v_dbid bigint) RETURNS void
    LANGUAGE plpgsql
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $$
DECLARE
BEGIN
  -- The start_anon function is used to inform the parallel anonymization jobs
  -- that's everything is ready. Those jobs wil start their work only when they
  -- see this specific status, which will have for effect to really anonymize
  -- the source database.
  --
  UPDATE custanon.parallel SET state='ready', startedat=NULL, endedat=NULL WHERE (state='wait' OR state='done') AND dbid=v_dbid;
END;
$$;


ALTER FUNCTION custanon.start_anon(v_dbid bigint) OWNER TO ninjanon;

