--
-- Name: pwdfile(text); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.pwdfile(file text) RETURNS SETOF text
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- the pwdfile function is used to read the content of a text file
  -- inside the filesystem. This content must be only a unique line of text
  -- and this is to simply take the password needed to connect on the
  -- source database. By the way, Ninjanon proceed this way to avoid providing
  -- your database passwords in clear directly as a parameter of the Ninjanon
  -- functions.
  --
  CREATE TEMP TABLE IF NOT EXISTS tmp_pwdfile (content text) ON COMMIT DROP;
  EXECUTE 'COPY tmp_pwdfile FROM ''' || file || '''';
  RETURN QUERY SELECT content FROM tmp_pwdfile LIMIT 1;
END;
$$;


ALTER FUNCTION custanon.pwdfile(file text) OWNER TO ninjanon;

--
-- Name: reset_anon(bigint); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.reset_anon(v_dbid bigint) RETURNS void
    LANGUAGE plpgsql
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $$
DECLARE
BEGIN
  -- The reset_anon function is used to reset the anonymization results of
  -- a previously executed anonymization. Of course that will not change the
  -- anonymized DATA if they have been injected in the target (or source) database
  -- but it's used when the anonymization model for a source database is under
  -- construction: it allows to restart the anonymization process again and
  -- again until you're happy with the results and without resetting some data
  -- but only the ones needed.
  --
  UPDATE custanon.parallel SET state='wait', startedat=NULL, endedat=NULL WHERE dbid=v_dbid;
  UPDATE custanon.counts SET startedat=NULL, endedat=NULL, error=false, err_msg=NULL, err_detail=NULL, err_hint=NULL, err_sqlstate=NULL, err_constraint=NULL, csvinject_time=NULL, rebuild_time=NULL, pid=NULL, anon_time=NULL WHERE dbid=v_dbid;
  UPDATE custanon.splitter_read SET startedat=NULL, endedat=NULL, pid=NULL WHERE dbid=v_dbid;
  DELETE FROM custanon.splitter WHERE dbid=v_dbid;
END;
$$;


ALTER FUNCTION custanon.reset_anon(v_dbid bigint) OWNER TO ninjanon;

--
-- Name: setconfig(text, text); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.setconfig(v_var text, v_val text) RETURNS void
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- the setconfig function is used to add or update a configuration
  -- parameter with its value in the config SQL table.
  --
  INSERT INTO custanon.config(var, val) VALUES (v_var, v_val) ON CONFLICT(var) DO UPDATE SET val=v_val, updatedon=now();
END;
$$;


ALTER FUNCTION custanon.setconfig(v_var text, v_val text) OWNER TO ninjanon;

--
-- Name: splitter(text, bigint, text, text); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.splitter(v_projectname text, v_dbid bigint, v_tbl text, v_srcfile text) RETURNS void
    LANGUAGE plpgsql SECURITY DEFINER
    AS $_$
DECLARE
  nblines integer := (custanon.getconfig('splitter', '300000')::integer);
  nbentries integer;
  cmd text;
BEGIN
  -- The splitter function splits the source file into several files
  -- and record the file parts in splitter table.
  -- The original file MUST be a CSV text file.
  --
  cmd := format(
    $f$
    COPY tmp_splitter_%s(content) FROM PROGRAM 'split --verbose -l %s -a 8 -d %s %s.'
    $f$,
    v_tbl, nblines, v_srcfile, v_srcfile);
  EXECUTE 'CREATE TEMP TABLE IF NOT EXISTS tmp_splitter_' || v_tbl || ' (dbid bigint default ' || v_dbid || ', tbl text default ''' || v_tbl || ''', content text, insertedat timestamp not null default now()) ON COMMIT DROP';
  EXECUTE cmd;
  EXECUTE 'SELECT count(*) FROM tmp_splitter_' || v_tbl || ' WHERE dbid=' || v_dbid || ' AND tbl=''' || v_tbl || '''' INTO nbentries;
  EXECUTE 'INSERT INTO custanon.splitter(projectname, nb, dbid, tbl, content, insertedat, state) SELECT ''' || v_projectname || ''', ' || nbentries || ', dbid, tbl, substring(content, ''''''(.*)''''$''), insertedat, ''ready'' FROM tmp_splitter_' || v_tbl;

  -- Delete the source file once splitted
  --
  cmd := format(
    $f$
    COPY tmp_splitter_%s(content) FROM PROGRAM 'rm -f %s'
    $f$,
    v_tbl, v_srcfile);
  EXECUTE cmd;
END;
$_$;


ALTER FUNCTION custanon.splitter(v_projectname text, v_dbid bigint, v_tbl text, v_srcfile text) OWNER TO ninjanon;

--
-- Name: splitter_read(text, text, bigint); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.splitter_read(v_dstdbtech text, v_projectname text, v_dbid bigint) RETURNS void
    LANGUAGE plpgsql SECURITY DEFINER
    AS $$
DECLARE
  splitread boolean := (custanon.getconfig('splitread', 'true')::boolean);
  nblines float := (custanon.getconfig('splitter', '300000')::float);
  nbentries integer;
  i bigint;
  r1 RECORD;
BEGIN
  -- split the SQL table into several parts and record them in splitter_read table
  -- only if we are in csvsplitinject mode and if splitread feature is enabled.
  --
  -- clean the splitter_read table first
  DELETE FROM custanon.splitter_read WHERE dbid=v_dbid;

  IF splitread=true AND v_dstdbtech='csvsplitinject' THEN
    -- add the SQL tables having no more than nblines tuples as a unique part in splitter_read table
    INSERT INTO custanon.splitter_read(projectname, dbid, tbl, shiftto, nbtuples, content) SELECT v_projectname, v_dbid, t0.tbl, 0, nblines, t0.tbl || '.csv.00000000' FROM custanon.counts t0 WHERE t0.dbid=v_dbid AND t0.nb>0 AND t0.nb<=nblines;

    -- add the SQL tables having more than nblines tuples as several parts in splitter_read table
    FOR r1 IN SELECT t0.tbl, t0.nb, ceil(t0.nb/nblines)-1 AS nbparts FROM custanon.counts t0 WHERE t0.dbid=v_dbid and t0.nb>nblines
    LOOP
      FOR i IN 0..r1.nbparts
      LOOP
        INSERT INTO custanon.splitter_read(projectname, dbid, tbl, nb, shiftto, nbtuples, content) VALUES (v_projectname, v_dbid, r1.tbl, r1.nbparts+1, i*nblines, nblines, r1.tbl || '.csv.' || to_char(i, 'FM09999999'));
      END LOOP;
    END LOOP;
  ELSE
    INSERT INTO custanon.splitter_read(projectname, dbid, tbl, insertedat, content) SELECT v_projectname, v_dbid, t0.tbl, now(), t0.tbl || '.csv.00000000' FROM custanon.counts t0 WHERE nb>0 AND t0.dbid=v_dbid;
  END IF;
END;
$$;


ALTER FUNCTION custanon.splitter_read(v_dstdbtech text, v_projectname text, v_dbid bigint) OWNER TO ninjanon;

--
-- Name: start_anon(bigint, boolean); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.start_anon(v_dbid bigint, v_autoclean boolean DEFAULT false) RETURNS void
    LANGUAGE plpgsql
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $$
DECLARE
  params RECORD;
  r1 RECORD;
  error_msg TEXT;
  error_detail TEXT;
  error_hint TEXT;
  error_sqlstate TEXT;
  error_col TEXT;
  error_tbl TEXT;
  error_constraint TEXT;
BEGIN
  -- The start_anon function is used to inform the parallel anonymization jobs
  -- that's everything is ready. Those jobs wil start their work only when they
  -- see this specific status, which will have for effect to really anonymize
  -- the source database.
  --
  SELECT INTO params 'srcdb_' || t0.dbid AS sourcefdw, t1.dbtech AS srcdbtech, t1.sourceschema AS f_srcschema, t0.projectname, t0.dstdbtech, t0.projectname || t1.dbtech AS srcschema, t0.projectname || t0.dstdbtech AS dstschema, t0.projectname || 'adm' AS schemaowner FROM custanon.parallel t0, custanon.dbsources t1 WHERE t0.dbid=t1.id AND t0.dbid=v_dbid LIMIT 1;

  -- disable all indexes, FKs, checks and set NOLOGGING on all tables
  -- to be anonymized if mode is csvsplitinject
  IF params.dstdbtech='csvsplitinject' OR params.dstdbtech='irdw' THEN
    -- For ORACLE:
    --
    IF params.srcdbtech='oracle' THEN
      PERFORM custanon.logging(v_dbid, '  Disable FKs, checks, indexes, triggers and set NOLOGGING...');
      EXECUTE 'SET ROLE ' || params.schemaowner;

      -- disable all FKs and checks
--      FOR r1 IN EXECUTE format('SELECT t0.table_name, t0.constraint_name FROM %s.user_constraints t0, custanon.counts t1 WHERE t1.dbid=%s AND t0.table_name=t1.tbl AND t0.constraint_type=''R''', srcschema, sourcedbid)
      FOR r1 IN EXECUTE format('SELECT t0.table_name, t0.constraint_name FROM %s.user_constraints t0 WHERE (t0.constraint_type=''R'' OR t0.constraint_type=''C'') AND (search_condition IS NULL OR search_condition NOT ILIKE ''%%is not null%%'')', params.srcschema)
      LOOP
        BEGIN
          EXECUTE 'SELECT ' || params.srcschema || '.oracle_execute(''' || params.sourcefdw ||''', ''ALTER TABLE ' || params.f_srcschema || '.' || r1.table_name || ' DISABLE CONSTRAINT ' || r1.constraint_name || ' '')';
        EXCEPTION WHEN OTHERS THEN
          GET STACKED DIAGNOSTICS error_sqlstate=RETURNED_SQLSTATE, error_col=COLUMN_NAME, error_constraint=CONSTRAINT_NAME, error_tbl=TABLE_NAME, error_msg=MESSAGE_TEXT, error_detail=PG_EXCEPTION_DETAIL, error_hint=PG_EXCEPTION_HINT;
          UPDATE custanon.counts SET error=true, err_msg=error_msg, err_detail=error_detail, err_hint=error_hint, err_sqlstate=error_sqlstate, err_col=error_col, err_constraint=error_constraint, err_tbl=error_tbl WHERE tbl=r1.tbl AND dbid=v_dbid;
        END;
      END LOOP;

      -- disable all indexes except the one used for anonymization process (PKs and *ANON_PK*)
      -- FOR r1 IN EXECUTE format('SELECT t0.index_name FROM %s.user_indexes t0, custanon.counts t1 WHERE t1.dbid=%s AND t0.table_name=t1.tbl AND t0.index_type=''NORMAL'' AND t0.index_name NOT LIKE ''%%'' || t1.pk_colname || ''%%''', params.srcschema, v_dbid)
      FOR r1 IN EXECUTE format('SELECT t0.index_name, COALESCE(t2.constraint_type<>''P'', true) AS notpk FROM custanon.counts t1, %s.user_indexes t0 LEFT JOIN %s.user_constraints t2 ON (t0.table_name=t2.table_name AND t0.index_name=t2.index_name) WHERE t1.dbid=%s AND t0.table_name=t1.tbl AND t0.index_type=''NORMAL'' AND t0.index_name NOT LIKE ''%%'' || t1.pk_colname || ''%%''', params.srcschema, params.srcschema, v_dbid)
      LOOP
        BEGIN
          IF r1.notpk=true THEN
            EXECUTE 'SELECT ' || params.srcschema || '.oracle_execute(''' || params.sourcefdw ||''', ''ALTER INDEX ' || r1.index_name || ' UNUSABLE'')';
          END IF;
        EXCEPTION WHEN OTHERS THEN
          GET STACKED DIAGNOSTICS error_sqlstate=RETURNED_SQLSTATE, error_col=COLUMN_NAME, error_constraint=CONSTRAINT_NAME, error_tbl=TABLE_NAME, error_msg=MESSAGE_TEXT, error_detail=PG_EXCEPTION_DETAIL, error_hint=PG_EXCEPTION_HINT;
          UPDATE custanon.counts SET error=true, err_msg=error_msg, err_detail=error_detail, err_hint=error_hint, err_sqlstate=error_sqlstate, err_col=error_col, err_constraint=error_constraint, err_tbl=error_tbl WHERE tbl=r1.tbl AND dbid=v_dbid;
        END;
      END LOOP;

      -- disable triggers, logging and set paralellism
      FOR r1 IN SELECT tbl FROM custanon.counts WHERE dbid=v_dbid
      LOOP
        BEGIN
          EXECUTE 'SELECT ' || params.srcschema || '.oracle_execute(''' || params.sourcefdw ||''', ''ALTER TABLE ' || params.f_srcschema || '.' || r1.tbl || ' DISABLE ALL TRIGGERS'')';
        EXCEPTION WHEN OTHERS THEN
          GET STACKED DIAGNOSTICS error_sqlstate=RETURNED_SQLSTATE, error_col=COLUMN_NAME, error_constraint=CONSTRAINT_NAME, error_tbl=TABLE_NAME, error_msg=MESSAGE_TEXT, error_detail=PG_EXCEPTION_DETAIL, error_hint=PG_EXCEPTION_HINT;
          UPDATE custanon.counts SET error=true, err_msg=error_msg, err_detail=error_detail, err_hint=error_hint, err_sqlstate=error_sqlstate, err_col=error_col, err_constraint=error_constraint, err_tbl=error_tbl WHERE tbl=r1.tbl AND dbid=v_dbid;
        END;

        BEGIN
          EXECUTE 'SELECT ' || params.srcschema || '.oracle_execute(''' || params.sourcefdw ||''', ''ALTER TABLE ' || params.f_srcschema || '.' || r1.tbl || ' NOLOGGING'')';
        EXCEPTION WHEN OTHERS THEN
          GET STACKED DIAGNOSTICS error_sqlstate=RETURNED_SQLSTATE, error_col=COLUMN_NAME, error_constraint=CONSTRAINT_NAME, error_tbl=TABLE_NAME, error_msg=MESSAGE_TEXT, error_detail=PG_EXCEPTION_DETAIL, error_hint=PG_EXCEPTION_HINT;
          UPDATE custanon.counts SET error=true, err_msg=error_msg, err_detail=error_detail, err_hint=error_hint, err_sqlstate=error_sqlstate, err_col=error_col, err_constraint=error_constraint, err_tbl=error_tbl WHERE tbl=r1.tbl AND dbid=v_dbid;
        END;

        BEGIN
          EXECUTE 'SELECT ' || params.srcschema || '.oracle_execute(''' || params.sourcefdw ||''', ''ALTER TABLE ' || params.f_srcschema || '.' || r1.tbl || ' PARALLEL (DEGREE 4)'')';
        EXCEPTION WHEN OTHERS THEN
          GET STACKED DIAGNOSTICS error_sqlstate=RETURNED_SQLSTATE, error_col=COLUMN_NAME, error_constraint=CONSTRAINT_NAME, error_tbl=TABLE_NAME, error_msg=MESSAGE_TEXT, error_detail=PG_EXCEPTION_DETAIL, error_hint=PG_EXCEPTION_HINT;
          UPDATE custanon.counts SET error=true, err_msg=error_msg, err_detail=error_detail, err_hint=error_hint, err_sqlstate=error_sqlstate, err_col=error_col, err_constraint=error_constraint, err_tbl=error_tbl WHERE tbl=r1.tbl AND dbid=v_dbid;
        END;
      END LOOP;

      RESET ROLE;
    END IF;
  END IF;

  UPDATE custanon.parallel SET state='ready', autoclean=v_autoclean, startedat=NULL, endedat=NULL WHERE (state='wait' OR state='done') AND dbid=v_dbid;
END;
$$;


ALTER FUNCTION custanon.start_anon(v_dbid bigint, v_autoclean boolean) OWNER TO ninjanon;

SET default_tablespace = '';

SET default_table_access_method = heap;

--
