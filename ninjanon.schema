--

CREATE FUNCTION custanon.pseudo_canton_addr(cant text, seed anyelement, salt text DEFAULT NULL::text) RETURNS text
    LANGUAGE plpgsql STABLE SECURITY DEFINER PARALLEL SAFE
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $$
DECLARE
  result TEXT;
BEGIN
  -- This is an anonymization function used to return a full
  -- address from a specific SWISS canton including street number,
  -- street name, postal code, city name extracted from the streets
  -- dictionnary (SQL table custanon.streets).
  -- It returns always the same result according to its input data.
  --
  SELECT COALESCE(anon.projection_to_oid(seed, COALESCE(salt, pg_catalog.current_setting('anon.salt')), 117) || ', ' || val || ' - ' || cp || ' ' || city, anon.notice_if_not_init()) INTO result
  FROM custanon.streets
  WHERE canton=cant AND oidcanton = anon.projection_to_oid(
    seed,
    COALESCE(salt, pg_catalog.current_setting('anon.salt')),
    (SELECT max(oidcanton) FROM custanon.streets WHERE canton=cant)
  );

  RETURN result;
END;
$$;


