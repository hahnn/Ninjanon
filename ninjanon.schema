--
-- Name: anonymize(bigint, text, text, text, text, text, boolean); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.anonymize(v_dbid bigint, csvfile text, v_dstdbtech text, v_projectname text, v_maskrole text, v_maskschema text DEFAULT 'anon'::text, counters_reset boolean DEFAULT false) RETURNS void
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- The anonymize functions call the generate_anon_rules fonction and set the
  -- ready state on parallel jobs in order to start the anonymization process immediately.
  -- Use this function to anonymize a same source database again and again after you
  -- successfully configured and validated the anonymization model for it.
  --
  -- this version of the function need the ID of an already configured
  -- source database to be anonymized, unlike the other one that needs all
  -- connection parameters on the source database
  --
  PERFORM custanon.generate_anon_rules(v_dbid, csvfile, v_dstdbtech, v_projectname, v_maskrole, v_maskschema, counters_reset);
  PERFORM custanon.start_anon(v_dbid, true);
  -- UPDATE custanon.parallel SET state='ready', autoclean=true WHERE dbid=v_dbid AND projectname=v_projectname AND maskrole=v_maskrole AND maskschema=v_maskschema;
END;
$$;


ALTER FUNCTION custanon.anonymize(v_dbid bigint, csvfile text, v_dstdbtech text, v_projectname text, v_maskrole text, v_maskschema text, counters_reset boolean) OWNER TO ninjanon;

--
-- Name: anonymize(text, text, text, text, text, text, text, text, text, text, text, boolean); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.anonymize(v_srcdbtech text, csvfile text, f_srcserver text, f_srcrole text, f_srcpwd text, f_srcschema text, f_datestyle text, v_dstdbtech text, v_projectname text, v_maskrole text, v_maskschema text DEFAULT 'anon'::text, counters_reset boolean DEFAULT false) RETURNS void
    LANGUAGE plpgsql
    AS $$
DECLARE
  lv_dbid bigint;
BEGIN
  -- The anonymize functions call the generate_anon_rules fonction and set the
  -- ready state on parallel jobs in order to start the anonymization process immediately.
  -- Use this function to anonymize a same source database again and again after you
  -- successfully configured and validated the anonymization model for it.
  --
  -- this version of the function need all the connection parameters on the source
  -- database to be anonymized, unlike the other one that needs only the ID of an already
  -- configured source database. That's the function to be called only the first time you
  -- want to work on a new source database to be anonymized, when it's not already existing
  -- (aka configured) in Ninjanon.
  --
  PERFORM custanon.generate_anon_rules(v_srcdbtech, csvfile, f_srcserver, f_srcrole, f_srcpwd, f_srcschema, f_datestyle, v_dstdbtech, v_projectname, v_maskrole, v_maskschema, counters_reset);
  lv_dbid := (SELECT t1.id FROM custanon.dbsources t1 WHERE t1.dbtech=v_srcdbtech AND t1.sourceserver=f_srcserver AND t1.sourceschema=f_srcschema AND t1.sourcerole=f_srcrole);
  PERFORM custanon.start_anon(lv_dbid, true);
  -- UPDATE custanon.parallel AS t0 SET state='ready', autoclean=true FROM custanon.dbsources t1 WHERE t1.dbtech=v_srcdbtech AND t1.sourceserver=f_srcserver AND t1.sourceschema=f_srcschema AND t1.id=t0.dbid AND t0.projectname=v_projectname AND t0.maskrole=v_maskrole AND t0.maskschema=v_maskschema;
END;
$$;


ALTER FUNCTION custanon.anonymize(v_srcdbtech text, csvfile text, f_srcserver text, f_srcrole text, f_srcpwd text, f_srcschema text, f_datestyle text, v_dstdbtech text, v_projectname text, v_maskrole text, v_maskschema text, counters_reset boolean) OWNER TO ninjanon;

--
-- Name: autoclean(); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.autoclean() RETURNS void
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- this autoclean function is to be called to clean all terminated
  -- aonymization jobs. Basically, a human shouldn't call it as it is called
  -- periodically and automatically via the SQL cron scheduler (pg_cron).
  -- This function will call the clean function if autoclean is configured to true.
  -- 
  PERFORM FROM custanon.parallel WHERE autoclean=true;
  IF FOUND THEN
    PERFORM custanon.clean();
  END IF;
END;
$$;


ALTER FUNCTION custanon.autoclean() OWNER TO ninjanon;

--
-- Name: autodiscovery(bigint, bigint, text, text, text); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.autodiscovery(v_analyzecnt bigint, v_sourcedbid bigint, v_srcdbtech text, v_projectname text, csvfile text) RETURNS text
    LANGUAGE plpgsql
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $_$
DECLARE
  sampling integer := (SELECT custanon.getconfig('sampling', '1000')::integer);
  nblines integer;
  nbtuples integer;
  numentry integer;
  l_samplednb integer;
  dictid_bck integer;
  pcmatch_bck float;
  request TEXT;
  anonrulesfdw TEXT;
  srcschema TEXT;
  schemaowner TEXT;
  proc TEXT;
  newcol TEXT;
  bestmethod RECORD;
  data_bestmethod RECORD;
  dict_bestmethod RECORD;
  data_lengths RECORD;
  r1 RECORD;
  r2 RECORD;
BEGIN
  srcschema := v_projectname || v_srcdbtech;
  schemaowner := v_projectname || 'adm';
  anonrulesfdw := 'anonrules_' || v_sourcedbid;

  -- AUTODISCOVERY
  -- If autorules mode is requested, determine what is the best anonymization
  -- method to be used
  PERFORM custanon.logging(v_sourcedbid, 'AUTORULES MODE ENABLED: trying to automatically configure the anonymization methods to be used...');
  IF csvfile='create' THEN
    PERFORM custanon.logging(v_sourcedbid, '  Start creation of CSV file describing possible anonymizations with auto discovery mode...');
    EXECUTE 'DROP TABLE IF EXISTS custanon.' || anonrulesfdw || '_autodiscovery';
    EXECUTE 'CREATE TABLE custanon.' || anonrulesfdw || '_autodiscovery(tbl text, col text, datatype regtype, colname_anonid int4, data_anonid int4, data_pct float NOT NULL DEFAULT 0, dict_anonid int4, dict_pct float NOT NULL DEFAULT 0, datatype_anonid int4, PRIMARY KEY(tbl, col))';
    EXECUTE 'CREATE TABLE custanon.' || anonrulesfdw || '_autorules(tbl text, col text, enabled text, anonfunc text, custom text, condition text, pretransformer text, transformer text)';

    --
    -- count the total number of columns to process in order to display the progression
    EXECUTE format('SELECT count(*) as nb FROM pg_catalog.pg_class c LEFT JOIN pg_catalog.pg_namespace n ON n.oid = c.relnamespace LEFT JOIN pg_catalog.pg_attribute a ON c.oid=a.attrelid WHERE n.nspname=''%s'' AND a.attnum>0 AND NOT a.attisdropped', srcschema) INTO nblines;
    numentry := 0;

    FOR r1 IN EXECUTE format('SELECT c.relname AS tbl, a.attname AS col, a.atttypid::regtype AS datatype FROM pg_catalog.pg_class c LEFT JOIN pg_catalog.pg_namespace n ON n.oid = c.relnamespace LEFT JOIN pg_catalog.pg_attribute a ON c.oid=a.attrelid WHERE n.nspname=''%s'' AND a.attnum>0 AND NOT a.attisdropped ORDER BY c.relname, a.attnum', srcschema)
    LOOP
      numentry := numentry+1;
      --
      -- First, search using the column names of the tables
      PERFORM custanon.logging(v_sourcedbid, '  [' || numentry || '/' || nblines || '] Analyzing ' || r1.tbl || '.' || r1.col || '[' || r1.datatype || ']' || '...');
      request := 'INSERT INTO custanon.' || anonrulesfdw || '_autodiscovery(tbl, col, datatype, colname_anonid, data_anonid, data_pct, dict_anonid, dict_pct, datatype_anonid) VALUES (''' || r1.tbl || ''', ''' || r1.col || ''', ''' || r1.datatype || '''::regtype, ';
      SELECT INTO bestmethod id, anonfunc FROM custanon.finders WHERE regexp_like(lower(r1.col), matcher)=true ORDER BY priority LIMIT 1;
      IF FOUND THEN
        PERFORM custanon.logging(v_sourcedbid, '    Found COLUMN NAME method: ' || bestmethod.anonfunc);
        IF bestmethod.anonfunc='#NOOP#' THEN
          request := request || 'NULL, ';
--          proc := format($internal$
--            INSERT INTO custanon.%I_autorules(tbl, col, enabled) VALUES('%s', '%s', 'false');
--          $internal$, anonrulesfdw, r1.tbl, r1.col);
        ELSE
          request := request || bestmethod.id || ', ';
--          proc := format($internal$
--            INSERT INTO custanon.%I_autorules(anonfunc, tbl, col, enabled) VALUES('%s', '%s', '%s', 'true');
--          $internal$, anonrulesfdw, replace(bestmethod.anonfunc, '''', ''''''), r1.tbl, r1.col);
        END IF;
      ELSE
        request := request || 'NULL, ';
        PERFORM custanon.logging(v_sourcedbid, '    No COLUMN NAME method found');
--        proc := format($internal$
--          INSERT INTO custanon.%I_autorules(tbl, col, enabled) VALUES('%s', '%s', 'false');
--        $internal$, anonrulesfdw, r1.tbl, r1.col);
      END IF;
--      EXECUTE proc;

      --
      -- Second, search by sampling the content of the tables for all columns
      IF r1.datatype='text'::regtype OR r1.datatype='character varying'::regtype OR r1.datatype='character'::regtype THEN
        proc := format($internal$
          SELECT count(*) AS nbtuples FROM (SELECT 1 FROM %s.%s WHERE %s IS NOT NULL LIMIT %s)
        $internal$, srcschema, r1.tbl, r1.col, sampling);
        EXECUTE 'SET ROLE ' || schemaowner;
        EXECUTE proc INTO nbtuples;

        proc := format($internal$
          WITH result AS (
            WITH sampled AS (
              SELECT %s AS data FROM %s.%s WHERE %s IS NOT NULL LIMIT %s
            )
            SELECT t1.regexid, t1.anonfunc, t0.data ~ t1.matcher AS match, count(*) AS nb FROM sampled t0, custanon.datafinders t1 GROUP BY t1.regexid, t1.anonfunc, match
          )
          SELECT regexid, anonfunc, nb, CAST(nb AS float) / CAST(%s AS float) * 100.0 AS pct FROM result WHERE match=true ORDER BY nb DESC LIMIT 1;
        $internal$, r1.col, srcschema, r1.tbl, r1.col, sampling, nbtuples);
        EXECUTE proc INTO data_bestmethod;
        RESET ROLE;
        IF data_bestmethod IS NULL THEN
          PERFORM custanon.logging(v_sourcedbid, '    No DATA method found');
          request := request || 'NULL, 0, ';
        ELSE
          PERFORM custanon.logging(v_sourcedbid, '    Found DATA method (' || data_bestmethod.pct || '%): ' || data_bestmethod.anonfunc);
          request := request || data_bestmethod.regexid || ', ' || data_bestmethod.pct || ', ';
        END IF;
      ELSE
        request := request || 'NULL, 0, ';
      END IF;

      --
      -- third, search by comparison with dictionnaries
      IF r1.datatype='text'::regtype OR r1.datatype='character varying'::regtype OR r1.datatype='character'::regtype THEN
        EXECUTE 'SET ROLE ' || schemaowner;
        EXECUTE proc INTO nbtuples;

        pcmatch_bck := 0.0;

        -- count the number of tuples in the sample
        PERFORM custanon.logging(v_sourcedbid, '    Counting number of tuples in the sample...');
        proc := format($internal$
          SELECT count(*) AS samplednb FROM (SELECT DISTINCT lower(%s) AS data FROM %s.%s WHERE %s IS NOT NULL LIMIT %s)
        $internal$, r1.col, srcschema, r1.tbl, r1.col, sampling);
        EXECUTE proc INTO dict_bestmethod;
        l_samplednb := dict_bestmethod.samplednb;

        -- check minimum and maximum lengths of the sampled data
        PERFORM custanon.logging(v_sourcedbid, '    Checking data minimum and maximum lengths of the sample...');
        proc := format($internal$
          SELECT min(length(data)) AS lmin, max(length(data)) AS lmax FROM (SELECT DISTINCT lower(%s) AS data FROM %s.%s WHERE %s IS NOT NULL LIMIT %s)
        $internal$, r1.col, srcschema, r1.tbl, r1.col, sampling);
        EXECUTE proc INTO data_lengths;

        FOR r2 IN SELECT dictid, dicttbl, dictcol, anonfunc, usecommon, lmin, lmax FROM custanon.dictfinders ORDER BY priority
        LOOP
          -- if the sample is not valid in term of length
          -- then it's even not necessary to compare against the dictionnary
          PERFORM custanon.logging(v_sourcedbid, '    Checking data length (MIN:' || r2.lmin || ', MAX:' || r2.lmax || ') of a sample of ' || l_samplednb || ' tuples against ' || r2.dicttbl || ' dictionnary...');
          IF data_lengths.lmin<r2.lmin OR data_lengths.lmax>r2.lmax THEN
            PERFORM custanon.logging(v_sourcedbid, '      Cancel comparison against ' || r2.dicttbl || ' dictionnary because of data length (MIN:' || data_lengths.lmin || ', MAX:' || data_lengths.lmax || ') outside boundaries');
          ELSE
            PERFORM custanon.logging(v_sourcedbid, '    Comparing a sample of ' || l_samplednb || ' tuples against ' || r2.dicttbl || ' dictionnary...');

            IF r2.usecommon=true THEN
              proc := format($internal$
                WITH sampled AS (
                  SELECT DISTINCT lower(%s) AS data FROM %s.%s WHERE %s IS NOT NULL LIMIT %s
                ),
                dict AS (
                  SELECT DISTINCT lower(%s) AS dictval FROM %s WHERE common=%s
                )
                SELECT %s AS tbl, %s AS col, %s AS dictid, %s AS samplednb, (SELECT count(*) FROM dict) AS dictnb, count(*) AS nb, count(*)::float/((SELECT count(*)::float FROM dict)*%s)*100 AS matchfactor, count(*)::float/%s AS pcmatch
                FROM sampled, dict
                WHERE sampled.data ~ dict.dictval=true
              $internal$, r1.col, srcschema, r1.tbl, r1.col, sampling, r2.dictcol, r2.dicttbl, r2.common, r1.tbl, r1.col, r2.dictid, l_samplednb, l_samplednb, l_samplednb);
            ELSE
              proc := format($internal$
                WITH sampled AS (
                  SELECT DISTINCT lower(%s) AS data FROM %s.%s WHERE %s IS NOT NULL LIMIT %s
                ),
                dict AS (
                  SELECT DISTINCT lower(%s) AS dictval FROM %s
                )
                SELECT %s AS tbl, %s AS col, %s AS dictid, %s AS samplednb, (SELECT count(*) FROM dict) AS dictnb, count(*) AS nb, count(*)::float/((SELECT count(*)::float FROM dict)*%s)*100 AS matchfactor, count(*)::float/%s AS pcmatch
                FROM sampled, dict
                WHERE sampled.data ~ dict.dictval=true
              $internal$, r1.col, srcschema, r1.tbl, r1.col, sampling, r2.dictcol, r2.dicttbl, r1.tbl, r1.col, r2.dictid, l_samplednb, l_samplednb, l_samplednb);
            END IF;
            EXECUTE proc INTO dict_bestmethod;

            PERFORM custanon.logging(v_sourcedbid, '    Matching rate against ' || r2.dicttbl || ' dictionnary: ' || dict_bestmethod.pcmatch*100 || '%');

            IF dict_bestmethod.pcmatch>pcmatch_bck THEN
              PERFORM custanon.logging(v_sourcedbid, '    Best dictionnary selected is now: ' || r2.dicttbl);
              pcmatch_bck := dict_bestmethod.pcmatch;
              dictid_bck := r2.dictid;
            END IF;
          END IF;
        END LOOP;

        RESET ROLE;

        request := request || dictid_bck || ', ' || pcmatch_bck || ', ';
      ELSE
        request := request || 'NULL, 0, ';
      END IF;

      --
      -- fourth, search using the column data type
      -- (to be implemeted if needed)
      request := request || 'NULL)';

      --
      -- insert the results of discovery methods in the autodiscovery table
      EXECUTE request;
    END LOOP;

    EXECUTE 'INSERT INTO custanon.' || anonrulesfdw || '_autorules(tbl, col, anonfunc, enabled)  SELECT t0.tbl, t0.col, COALESCE(t1.anonfunc, t2.anonfunc) AS anonfunc, CASE WHEN COALESCE(t1.anonfunc, t2.anonfunc) IS NULL THEN false ELSE true END FROM custanon.' || anonrulesfdw || '_autodiscovery t0 LEFT JOIN custanon.finders t1 ON (t0.colname_anonid=t1.id) LEFT JOIN custanon.datafinders t2 ON (t0.data_anonid=t2.regexid) ORDER BY t0.tbl, t0.col';
  ELSE
    EXECUTE 'CREATE TABLE IF NOT EXISTS custanon.' || anonrulesfdw || '_autorules AS TABLE custanon.' || anonrulesfdw;
    -- EXECUTE 'UPDATE custanon.' || anonrulesfdw || '_autorules SET anonfunc=NULL';

    -- drop CSV FDW
    PERFORM custanon.logging(v_sourcedbid, 'Closing CSV file ' || csvfile || '...');
    EXECUTE 'DROP FOREIGN TABLE custanon.' || anonrulesfdw;
    EXECUTE 'DROP SERVER ' || anonrulesfdw;

    PERFORM custanon.logging(v_sourcedbid, 'Check for removed tables and columns in source database...');
    -- EXECUTE 'DELETE FROM custanon.' || anonrulesfdw || '_autorules WHERE NOT EXISTS (SELECT FROM pg_catalog.pg_class c LEFT JOIN pg_catalog.pg_namespace n ON n.oid = c.relnamespace LEFT JOIN pg_catalog.pg_attribute a ON c.oid=a.attrelid WHERE n.nspname=''' || srcschema || ''' AND a.attnum>0 AND NOT a.attisdropped AND left(custanon.' || anonrulesfdw || '_autorules.col)<>'''#UV#''' AND c.relname ILIKE custanon.' || anonrulesfdw || '_autorules.tbl AND a.attname ILIKE custanon.' || anonrulesfdw || '_autorules.col');
    FOR r1 IN EXECUTE format('SELECT tbl, col FROM custanon.%I_autorules AS t0 WHERE t0.tbl<>''#SALT#'' AND left(t0.col, 4)<>''#UV#''', anonrulesfdw)
    LOOP
      EXECUTE 'SELECT ''still exist'' FROM pg_catalog.pg_class c LEFT JOIN pg_catalog.pg_namespace n ON n.oid = c.relnamespace LEFT JOIN pg_catalog.pg_attribute a ON c.oid=a.attrelid WHERE n.nspname=''' || srcschema || ''' AND a.attnum>0 AND NOT a.attisdropped AND c.relname ILIKE ''' || r1.tbl || ''' AND a.attname ILIKE ''' || r1.col || '''' INTO newcol;
      IF newcol IS NULL THEN
        PERFORM custanon.logging(v_sourcedbid, '  Removing ' || r1.tbl || '.' || r1.col || '...');
        proc := format($internal$
          DELETE FROM custanon.%I_autorules WHERE tbl ILIKE '%s' AND col ILIKE '%s';
        $internal$, anonrulesfdw, r1.tbl, r1.col);
      END IF;
    END LOOP;

    PERFORM custanon.logging(v_sourcedbid, 'Check for new available anonymization methods on already declared tables and columns having no methods...');
    FOR r1 IN EXECUTE format('SELECT tbl, col, anonfunc FROM custanon.%I_autorules t0 WHERE t0.tbl<>''#SALT#'' AND left(t0.col, 4)<>''#UV#'' AND t0.anonfunc IS NULL', anonrulesfdw)
    LOOP
      PERFORM custanon.logging(v_sourcedbid, '  Finding best anon method for ' || r1.tbl || '.' || r1.col || '...');
      SELECT INTO bestmethod anonfunc FROM custanon.finders WHERE regexp_like(lower(r1.col), matcher)=true ORDER BY priority LIMIT 1;
      IF FOUND THEN
        PERFORM custanon.logging(v_sourcedbid, '    Configuring method: ' || bestmethod.anonfunc);
        proc := format($internal$
          UPDATE custanon.%I_autorules SET anonfunc='%s' WHERE tbl='%s' AND col='%s';
        $internal$, anonrulesfdw, replace(bestmethod.anonfunc, '''', ''''''), r1.tbl, r1.col);
        EXECUTE proc;
      ELSE
        PERFORM custanon.logging(v_sourcedbid, '    No method found');
      END IF;
    END LOOP;

    PERFORM custanon.logging(v_sourcedbid, 'Check for additional tables and columns in source database...');
    FOR r1 IN EXECUTE format('SELECT c.relname AS tbl, a.attname AS col, a.atttypid::regtype AS datatype FROM pg_catalog.pg_class c LEFT JOIN pg_catalog.pg_namespace n ON n.oid = c.relnamespace LEFT JOIN pg_catalog.pg_attribute a ON c.oid=a.attrelid WHERE n.nspname=''%s'' AND a.attnum>0 AND NOT a.attisdropped ORDER BY c.relname, a.attnum', srcschema)
    LOOP
      EXECUTE 'SELECT tbl FROM custanon.' || anonrulesfdw || '_autorules WHERE tbl ILIKE ''' || r1.tbl || ''' AND col ILIKE ''' || r1.col || '''' INTO newcol;
      IF newcol IS NULL THEN
        PERFORM custanon.logging(v_sourcedbid, '  Finding best anon method for ' || r1.tbl || '.' || r1.col || '[' || r1.datatype || ']' || '...');
        SELECT INTO bestmethod anonfunc FROM custanon.finders WHERE regexp_like(lower(r1.col), matcher)=true ORDER BY priority LIMIT 1;
        IF FOUND THEN
          PERFORM custanon.logging(v_sourcedbid, '    Configuring method: ' || bestmethod.anonfunc);
          IF bestmethod.anonfunc='#NOOP#' THEN
            proc := format($internal$
              INSERT INTO custanon.%I_autorules(tbl, col, enabled) VALUES('%s', '%s', 'false');
            $internal$, anonrulesfdw, r1.tbl, r1.col);
          ELSE
            proc := format($internal$
              INSERT INTO custanon.%I_autorules(anonfunc, tbl, col, enabled) VALUES('%s', '%s', '%s', 'true');
            $internal$, anonrulesfdw, replace(bestmethod.anonfunc, '''', ''''''), r1.tbl, r1.col);
          END IF;
        ELSE
          PERFORM custanon.logging(v_sourcedbid, '    No method found');
          proc := format($internal$
            INSERT INTO custanon.%I_autorules(tbl, col, enabled) VALUES('%s', '%s', 'false');
          $internal$, anonrulesfdw, r1.tbl, r1.col);
        END IF;
        EXECUTE proc;
      END IF;
    END LOOP;
  END IF;

  -- COPY content of the working table to file
  PERFORM custanon.logging(v_sourcedbid, 'Writing new CSV rules file to /tmp/' || anonrulesfdw || '_' || v_analyzecnt || '_autorules.csv');
  EXECUTE 'COPY custanon.' || anonrulesfdw || '_autorules TO ''/tmp/' || anonrulesfdw || '_' || v_analyzecnt || '_autorules.csv'' WITH (FORMAT csv, HEADER, DELIMITER '';'')';

  -- drop working table
  EXECUTE 'DROP TABLE custanon.' || anonrulesfdw || '_autorules';
  --EXECUTE 'DROP TABLE custanon.' || anonrulesfdw || '_autodiscovery';

  RETURN '';
END;
$_$;


ALTER FUNCTION custanon.autodiscovery(v_analyzecnt bigint, v_sourcedbid bigint, v_srcdbtech text, v_projectname text, csvfile text) OWNER TO ninjanon;

--
-- Name: clean(); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.clean() RETURNS text
    LANGUAGE plpgsql
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $$
DECLARE
  srcschema text;
  schemaowner text;
  r1 RECORD;
  r2 RECORD;
BEGIN
  -- the goal of this clean function is, for any source database for which
  -- the parallel anonymization jobs have been executed, to:
  --   * DROP the temporary Primary Keys that have been created for
  --     the purpose of the anonymization,
  --   * DROP the temporary indexes that have been created for the
  --     purpose of the temporary PKs,
  --   * DROP the foreign server with all its atatched objects using CASCADE
  --   * DELETE the parallel jobs that were created to anonymize the database
  -- 
  FOR r1 IN SELECT t0.dbid, t1.dbtech, t0.projectname, t0.maskrole, t0.maskschema FROM custanon.parallel t0, custanon.dbsources t1
    WHERE t0.dbid=t1.id AND (t0.state='done' OR t0.state='wait') GROUP BY t0.dbid, t1.dbtech, t0.projectname, t0.maskrole, t0.maskschema
    EXCEPT SELECT t0.dbid, t1.dbtech, t0.projectname, t0.maskrole, t0.maskschema FROM custanon.parallel t0, custanon.dbsources t1
    WHERE t0.dbid=t1.id AND (t0.state<>'done' AND t0.state<>'wait') GROUP BY t0.dbid, t1.dbtech, t0.projectname, t0.maskrole, t0.maskschema
  LOOP
    srcschema := r1.projectname || r1.dbtech;
    schemaowner := r1.projectname || 'adm';

    PERFORM custanon.logging(r1.dbid, 'Closing anonymisation of source ' || r1.dbtech || ', project ' || r1.projectname || ', mask role ' || r1.maskrole || ', mask schema ' || r1.maskschema);
    PERFORM custanon.logging(r1.dbid, '  Droping temporary PRIMARY KEYs...');
    FOR r2 IN SELECT t4.tbl,
      CASE WHEN ftoptions IS NULL THEN '' ELSE (SELECT pg_catalog.replace(pg_catalog.quote_literal(option_value), '''', '') FROM pg_catalog.pg_options_to_table(ftoptions) WHERE pg_catalog.quote_ident(option_name) ILIKE 'schema') END AS f_srcschema
      FROM pg_catalog.pg_foreign_table t0
      INNER JOIN pg_catalog.pg_class t1 ON t1.oid = t0.ftrelid
      INNER JOIN pg_catalog.pg_namespace t2 ON t2.oid = t1.relnamespace
      INNER JOIN pg_catalog.pg_foreign_server t3 ON t3.oid = t0.ftserver
      INNER JOIN custanon.counts t4 ON t4.tbl ILIKE t1.relname
      WHERE t4.anon_pk=true AND t2.nspname ILIKE srcschema COLLATE pg_catalog.default
    LOOP
      IF r1.dbtech='oracle' THEN
        EXECUTE 'SET ROLE ' || schemaowner;
        PERFORM custanon.logging(r1.dbid, '    Droping index on source DB: I_ANON_PK_' || r2.tbl);
        EXECUTE 'SELECT ' || srcschema || '.oracle_execute(''srcdb_' || r1.dbid || ''', ''DROP INDEX IF EXISTS I_ANON_PK_' || r2.tbl || ''')';
        PERFORM custanon.logging(r1.dbid, '    Droping serial column with PK on source DB: ' || r2.f_srcschema || '.' || r2.tbl || '(ANON_PK)');
        EXECUTE 'SELECT ' || srcschema || '.oracle_execute(''srcdb_' || r1.dbid || ''', ''ALTER TABLE ' || r2.f_srcschema || '.' || r2.tbl || ' DROP COLUMN ANON_PK'')';
        RESET ROLE;
        UPDATE custanon.counts SET pk=false, anon_pk=false WHERE tbl=r2.tbl AND dbid=r1.dbid;
      END IF;
    END LOOP;
    PERFORM custanon.logging(r1.dbid, '  Droping FDW server srcdb_' || r1.dbid || '...');
    EXECUTE 'DROP SERVER IF EXISTS srcdb_' || r1.dbid || ' CASCADE';
    PERFORM custanon.logging(r1.dbid, '  Cleaning parallel jobs...');
    DELETE FROM custanon.parallel WHERE dbid=r1.dbid AND projectname=r1.projectname AND maskrole=r1.maskrole AND maskschema=r1.maskschema;
  END LOOP;

  RETURN '';
END;
$$;


ALTER FUNCTION custanon.clean() OWNER TO ninjanon;

--
-- Name: clean(bigint); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.clean(v_dbid bigint) RETURNS text
    LANGUAGE plpgsql
    SET search_path TO 'pg_catalog', 'pg_temp'
    AS $$
DECLARE
  srcschema text;
  schemaowner text;
  r1 RECORD;
  r2 RECORD;
BEGIN
  -- the goal of this clean function is, for a specific source database for which
  -- the parallel anonymization jobs have been executed, to:
  --   * DROP the temporary Primary Keys that have been created for
  --     the purpose of the anonymization,
  --   * DROP the temporary indexes that have been created for the
  --     purpose of the temporary PKs,
  --   * DROP the foreign server with all its atatched objects using CASCADE
  --   * DELETE the parallel jobs that were created to anonymize the database
  --
  SELECT INTO r1 t1.dbtech, t0.projectname, t0.maskrole, t0.maskschema FROM custanon.parallel t0, custanon.dbsources t1 WHERE t0.dbid=t1.id AND (t0.state='done' OR t0.state='wait') AND t0.dbid=v_dbid GROUP BY t1.dbtech, t0.projectname, t0.maskrole, t0.maskschema EXCEPT SELECT t1.dbtech, t0.projectname, t0.maskrole, t0.maskschema FROM custanon.parallel t0, custanon.dbsources t1 WHERE t0.dbid=t1.id AND (t0.state<>'done' AND t0.state<>'wait') AND t0.dbid=v_dbid GROUP BY t1.dbtech, t0.projectname, t0.maskrole, t0.maskschema;

  srcschema := r1.projectname || r1.dbtech;
  schemaowner := r1.projectname || 'adm';

  PERFORM custanon.logging(v_dbid, 'Closing anonymisation of source ' || r1.dbtech || ', project ' || r1.projectname || ', mask role ' || r1.maskrole || ', mask schema ' || r1.maskschema);
  PERFORM custanon.logging(v_dbid, '  Droping temporary PRIMARY KEYs, UNIQUE INDEXes or SEQUENCES...');
  FOR r2 IN SELECT t4.tbl, t4.anon_pk, t4.anon_ui, t4.anon_seq,
    CASE WHEN ftoptions IS NULL THEN '' ELSE (SELECT pg_catalog.replace(pg_catalog.quote_literal(option_value), '''', '') FROM pg_catalog.pg_options_to_table(ftoptions) WHERE pg_catalog.quote_ident(option_name) ILIKE 'schema') END AS f_srcschema
    FROM pg_catalog.pg_foreign_table t0
    INNER JOIN pg_catalog.pg_class t1 ON t1.oid = t0.ftrelid
    INNER JOIN pg_catalog.pg_namespace t2 ON t2.oid = t1.relnamespace
    INNER JOIN pg_catalog.pg_foreign_server t3 ON t3.oid = t0.ftserver
    INNER JOIN custanon.counts t4 ON t4.tbl ILIKE t1.relname
    WHERE (t4.anon_pk=true OR t4.anon_ui=true) AND t2.nspname ILIKE srcschema COLLATE pg_catalog.default
  LOOP
    IF r1.dbtech='oracle' THEN
      EXECUTE 'SET ROLE ' || schemaowner;
      IF r2.anon_ui=true THEN
        PERFORM custanon.logging(v_dbid, '    Droping index on source DB: I_ANON_PK_' || r2.tbl);
        BEGIN
          EXECUTE 'SELECT ' || srcschema || '.oracle_execute(''srcdb_' || v_dbid || ''', ''DROP INDEX I_ANON_PK_' || r2.tbl || ''')';
        EXCEPTION WHEN OTHERS THEN
        END;
      END IF;
      IF r2.anon_seq=true THEN
        PERFORM custanon.logging(v_dbid, '    Droping sequence on source DB: I_ANON_SEQ_' || r2.tbl);
        BEGIN
          EXECUTE 'SELECT ' || srcschema || '.oracle_execute(''srcdb_' || v_dbid || ''', ''DROP SEQUENCE I_ANON_SEQ_' || r2.tbl || ''')';
        EXCEPTION WHEN OTHERS THEN
        END;
      END IF;
      PERFORM custanon.logging(v_dbid, '    Droping serial column with PK on source DB: ' || r2.f_srcschema || '.' || r2.tbl || '(ANON_PK)');
      BEGIN
        EXECUTE 'SELECT ' || srcschema || '.oracle_execute(''srcdb_' || v_dbid || ''', ''ALTER TABLE ' || r2.f_srcschema || '.' || r2.tbl || ' DROP COLUMN ANON_PK'')';
      EXCEPTION WHEN OTHERS THEN
      END;
      RESET ROLE;
      UPDATE custanon.counts SET pk=false, anon_pk=false, anon_ui=false, anon_seq=false WHERE tbl=r2.tbl AND dbid=v_dbid;
    END IF;
  END LOOP;
  PERFORM custanon.logging(v_dbid, '  Droping FDW server srcdb_' || v_dbid || '...');
  EXECUTE 'DROP SERVER IF EXISTS srcdb_' || v_dbid || ' CASCADE';
  PERFORM custanon.logging(v_dbid, '  Cleaning parallel jobs...');
  DELETE FROM custanon.parallel WHERE dbid=v_dbid AND projectname=r1.projectname AND maskrole=r1.maskrole AND maskschema=r1.maskschema;

  UPDATE custanon.counts SET startedat=NULL, endedat=NULL, error=false, err_msg=NULL, err_detail=NULL, err_hint=NULL, err_sqlstate=NULL, err_constraint=NULL, projected_anon_time=NULL, init_time=NULL, init_startedat=NULL, csvinject_time=NULL, rebuild_time=NULL, pid=NULL, anon_time=NULL WHERE dbid=v_dbid;
  DELETE FROM custanon.splitter_read WHERE dbid=v_dbid;
  DELETE FROM custanon.splitter WHERE dbid=v_dbid;

  RETURN '';
END;
$$;


ALTER FUNCTION custanon.clean(v_dbid bigint) OWNER TO ninjanon;

--
-- Name: existconfig(text); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.existconfig(v_var text) RETURNS boolean
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- the existconfig function check if the configuration parameter
  -- named in the v_var input variable is existing in the config SQL table
  -- and returns true if it is, false otherwise.
  -- 
  PERFORM FROM custanon.config WHERE var=v_var;
  IF FOUND THEN
    RETURN true;
  END IF;

  RETURN false;
END;
$$;


ALTER FUNCTION custanon.existconfig(v_var text) OWNER TO ninjanon;

--
-- Name: f_getjewel(); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.f_getjewel() RETURNS text
    LANGUAGE plpgsql
    AS $$
DECLARE
  wrongmachineid boolean;
  chestexist boolean;
  chestsize integer;
  chestjumps integer;
  zerow RECORD;
BEGIN
  -- the f_getjewel function comes from the main PGNinja project set of PL/PGSQL
  -- functions.
  -- It's basically used to extract a jewel from the chest.
  -- The chest must be seen as a huge amount of random bytes (or textual characters)
  -- recorded in the pgninja_chest table. From this sea of bytes, is extracted a few
  -- bytes (or characters) used to define a small string limited in size.
  -- This size is determined by the total size of the chest divided by a jump factor
  -- we make in the sea of bytes inside the chest.
  -- The chestsize is configured by default to 8192 bytes.
  -- The jump interval is configured by default to 88 bytes.
  -- The resulting jewel obtained is used as the encryption passphrase that will be
  -- used with pg_cryto functions, in order to encrypt and decrypt important information
  -- that are needed by Ninjanon, like for example the passwords of the users needed
  -- to connect on the source (and destination) databases.
  -- The content of the chest is machine dependant. That means if one decide to DUMP
  -- the Ninjanon database with all its content to restore it on another PostgreSQL
  -- server, the machine ID will be different then the chest content will be erased
  -- and regenerated, with the effect of completely changing the extracted jewel,
  -- thus changing the passphrase. At the end of the day, that means you'll be unable
  -- to decrypt passwords stored for the configured source databases.
  -- 
  chestsize := (custanon.getconfig('chestsize', '8192')::integer);
  chestjumps := (custanon.getconfig('chestjumps', '88')::integer);

  IF custanon.existconfig('machineid')=false THEN
    PERFORM custanon.setconfig('machineid', custanon.machineid());
    wrongmachineid := true;
  ELSE
    wrongmachineid := (SELECT custanon.machineid()<>custanon.getconfig('machineid'));
  END IF;

  chestexist := (SELECT count(*)>0 FROM custanon.pgninja_chest);
  IF chestexist=false OR (chestexist=true AND wrongmachineid=true) THEN
    SELECT INTO zerow string_agg(substr('abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-.,_:;?=)(][}{@', ceil (random() * 77)::integer, 1), NULL)::bytea AS chest FROM generate_series(1, chestsize);
    IF chestexist=true THEN
      TRUNCATE custanon.pgninja_chest;
    END IF;
    INSERT INTO custanon.pgninja_chest(chest) VALUES (zerow.chest);
  ELSE
    SELECT INTO zerow chest FROM custanon.pgninja_chest LIMIT 1;
  END IF;

  SELECT INTO zerow string_agg(substr(convert_from(zerow.chest, 'UTF8'), generate_series, 1), NULL) AS jewel FROM generate_series(1, chestsize, chestjumps);

  RETURN zerow.jewel;
END;
$$;


ALTER FUNCTION custanon.f_getjewel() OWNER TO ninjanon;

--
-- Name: fake_avs(); Type: FUNCTION; Schema: custanon; Owner: ninjanon
--

CREATE FUNCTION custanon.fake_avs() RETURNS text
    LANGUAGE sql PARALLEL RESTRICTED
    SET search_path TO ''
    AS $$
  -- This is an anonymization function used to return a SWISS AVS number
  -- extracted randomly from the AVS dictionnary (SQL table custanon.avs)
  --
  WITH random AS (
    SELECT (pg_catalog.random()*last_value)::INTEGER%last_value+1 AS oid
    FROM custanon.avs_oid_seq
  )
  SELECT COALESCE(l.val, anon.notice_if_not_init())
  FROM random r LEFT JOIN custanon.avs l ON l.oid=r.oid;
$$;


ALTER FUNCTION custanon.fake_avs() OWNER TO ninjanon;

--
-- Name: FUNCTION fake_avs(); Type: SECURITY LABEL; Schema: custanon; Owner: ninjanon
--

SECURITY LABEL FOR anon ON FUNCTION custanon.fake_avs() IS 'TRUSTED';


